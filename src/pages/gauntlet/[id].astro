---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const res = await fetch(`https://gdrate.arcticwoof.xyz/v1/getGauntlets`);
  const gauntlets = await res.json() || [];
  
  return gauntlets.map(g => ({
    params: { id: g.gauntletId.toString() },
    props: { gauntlet: g }
  }));
}

const { gauntlet } = Astro.props;

if (!gauntlet) {
  return Astro.redirect('/gauntlets');
}

const layouts = gauntlet.layouts || [];

const getDifficultyPath = (diffValue, featValue) => {
  let diffName = "NA";
  let fileName = "na";
  
  if (diffValue === 1) { diffName = "AUTO"; fileName = "auto"; }
  else if (diffValue === 2) { diffName = "EASY"; fileName = "easy"; }
  else if (diffValue === 3) { diffName = "NORMAL"; fileName = "normal"; }
  else if (diffValue >= 4 && diffValue <= 5) { diffName = "HARD"; fileName = "hard"; }
  else if (diffValue >= 6 && diffValue <= 7) { diffName = "HARDER"; fileName = "harder"; }
  else if (diffValue >= 8 && diffValue <= 9) { diffName = "INSANE"; fileName = "insane"; }
  else if (diffValue === 10) { diffName = "EASY DEMON"; fileName = "easydemon"; }
  else if (diffValue === 15) { diffName = "MEDIUM DEMON"; fileName = "mediumdemon"; }
  else if (diffValue === 20) { diffName = "HARD DEMON"; fileName = "harddemon"; }
  else if (diffValue === 25) { diffName = "INSANE DEMON"; fileName = "insanedemon"; }
  else if (diffValue === 30) { diffName = "EXTREME DEMON"; fileName = "extremedemon"; }
  
  let featName = "no";
  if (featValue === 1) featName = "featured";
  else if (featValue === 2) featName = "epic";
  else if (featValue === 3) featName = "legendary";

  return `/difficulty/${diffName}/${fileName}_${featName}.png`;
};

const getStars = (diffValue) => {
  if (diffValue >= 10) return 10;
  return diffValue;
};
---

<Layout title={`${gauntlet.gauntletName} - Levels`}>
  <div class="list-container">
    <div class="header-row">
      <div style="display: flex; align-items: center; gap: 1rem;">
        <a href="/gauntlets" class="back-button">
          <img src="/buttons/RL_prev01.png" alt="Back" width="50" height="50" style="filter: drop-shadow(0 2px 4px rgba(0,0,0,0.4));" />
        </a>
        <h1 class="page-title pusab-font">{gauntlet.gauntletName}</h1>
      </div>
      <div class="stats-counter pusab-font">
        <div class="total-levels">Levels: {layouts.length}</div>
      </div>
    </div>
    
    <div class="layouts-list">
      {layouts.map((level) => (
        <div class="level-cell">
          <!-- Difficulty Face and Label -->
          <div class="difficulty-container">
            <img 
              src={getDifficultyPath(level.difficulty, level.featured)} 
              alt="Difficulty" 
              class="difficulty-face"
            />
          </div>

          <!-- Level Info -->
          <div class="level-info">
            <div class="name-row">
              <span class="level-name pusab-font">{level.levelName}</span>
              <span class="level-stars pusab-font">
                {getStars(level.difficulty)}
                <img src="/stats/RL_sparkMed.png" alt="Stars" class="stars-icon" />
              </span>
            </div>
            <div class="creator-row">
              <span class="by-label pusab-font">By</span>
              <span class="creator-name pusab-font">{level.creatorUsername}</span>
            </div>
          </div>

          <!-- Score and View Button -->
          <div class="action-container">
            <div class="featured-score">
              <span class="score-label">Featured Score:</span>
              <span class="score-value">{level.featuredScore}</span>
            </div>
            <a href={`/level/${level.levelId}`} class="view-button-link">
              <button class="view-button pusab-font">VIEW</button>
            </a>
          </div>
        </div>
      ))}
      
      {layouts.length === 0 && (
          <div class="empty-state pusab-font">
              <p>No levels found in this gauntlet.</p>
          </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .list-container {
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1rem;
    animation: fadeIn 0.5s ease-out;
  }

  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    position: relative;
  }

  .page-title {
    font-size: 2.5rem;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    margin: 0;
  }

  .stats-counter {
    background: rgba(0, 0, 0, 0.4);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 0.5rem 1rem;
    text-align: right;
    color: #ffd966;
    text-shadow: 1px 1px #000;
  }

  .total-levels {
    font-size: 1.2rem;
    color: white;
  }
  
  .back-button {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
      transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  
  .back-button:hover {
      transform: scale(1.1);
  }
  
  .back-button:active {
      transform: scale(0.95);
  }

  .layouts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .level-cell {
    background: linear-gradient(to bottom, #d2b48c 50%, #bc9b6a 50%);
    border: 4px solid #000;
    border-radius: 12px;
    padding: 0.8rem 1.5rem;
    display: flex;
    align-items: center;
    position: relative;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    transition: transform 0.2s ease;
  }

  .difficulty-container {
    margin-right: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 80px;
  }

  .difficulty-face {
    width: 100px;
    height: auto;
    filter: drop-shadow(0 0 5px rgba(255,255,255,0.3));
  }

  .level-info {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.2rem;
  }

  .name-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .level-name {
    font-size: 1.8rem;
    text-transform: uppercase;
    color: white;
    text-shadow: 2px 2px #000;
  }

  .level-stars {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 1.8rem;
    color: white;
    text-shadow: 2px 2px #000;
  }

  .stars-icon {
    width: 24px;
    height: auto;
  }

  .creator-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .by-label {
    color: #ffc800; /* Gold */
    font-size: 1.5rem;
    text-shadow: 1.5px 1.5px #000;
  }

  .creator-name {
    color: #ffc800; /* Gold */
    font-size: 1.5rem;
    text-shadow: 1.5px 1.5px #000;
  }

  .action-container {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    height: 100%;
    min-height: 80px;
  }

  .featured-score {
    font-family: inherit;
    font-size: 1rem;
    color: #ffd966;
    text-shadow: 1px 1px #000;
  }

  .score-value {
    margin-left: 0.2rem;
  }

  .view-button {
    background: linear-gradient(to bottom, #00d2ff, #0072ff);
    border: 3px solid #000;
    border-radius: 6px;
    color: white;
    padding: 0.4rem 1.2rem;
    font-size: 1.5rem;
    cursor: pointer;
    text-shadow: 1px 1px #000;
    box-shadow: 0 4px 0 #000;
    transition: all 0.1s;
  }

  .view-button:active {
    transform: translateY(2px);
    box-shadow: 0 2px 0 #000;
  }

  .view-button:hover {
    transform: scale(1.05);
  }
  
  .empty-state {
      text-align: center;
      padding: 3rem;
      background: rgba(0,0,0,0.3);
      border-radius: 12px;
      border: 3px solid #000;
      color: #ffc800;
      font-size: 1.5rem;
      text-shadow: 2px 2px #000;
  }

  @media (max-width: 600px) {
    .level-cell {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 1rem;
    }

    .difficulty-container {
      margin-right: 0;
      margin-bottom: 0.5rem;
    }

    .name-row, .creator-row {
      justify-content: center;
    }

    .action-container {
      align-items: center;
      margin-top: 1rem;
    }
  }
</style>
