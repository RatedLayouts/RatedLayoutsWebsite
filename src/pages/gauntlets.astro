---
export const prerender = false;
import Layout from '../layouts/Layout.astro';

const res = await fetch(`https://gdrate.arcticwoof.xyz/v1/getGauntlets`, {
  cache: 'no-store'
});
const gauntlets = await res.json() || [];

// Helper function to parse GD markdown description
function parseDescription(desc) {
  if (!desc) return "";
  let parsed = desc
    .replace(/<co>/g, '<span style="color: #ffc800;">')
    .replace(/<cr>/g, '<span style="color: #ff5555;">')
    .replace(/<cy>/g, '<span style="color: #ffff00;">')
    .replace(/<\/c>/g, '</span>')
    .replace(/\[(.*?)\]\(user:(\d+)\)/g, '<a href="/profile/$2" style="color: #00d2ff; text-decoration: underline;">$1</a>')
    .replace(/\*\*(.*?)\*\*/g, '<b>$1</b>')
    .replace(/\*(.*?)\*/g, '<i>$1</i>')
    .replace(/\r\n/g, '<br/>')
    .replace(/\n/g, '<br/>');
  return parsed;
}
---

<Layout title="Layout Gauntlets">
  <div class="list-container">
    <div class="header-row">
      <h1 class="page-title pusab-font">Layout Gauntlets</h1>
    </div>

    <div class="gauntlets-list">
      {gauntlets.map((gauntlet) => (
        <div class="gauntlet-cell">
           <!-- Gauntlet Image -->
           <div class="gauntlet-icon-container">
             <img src={`/gauntlet/RL_gauntlet-${gauntlet.gauntletId}.png`} alt={gauntlet.gauntletName} class="gauntlet-icon" />
           </div>

           <!-- Info -->
           <div class="gauntlet-info">
             <span class="gauntlet-name pusab-font">{gauntlet.gauntletName}</span>
           </div>

           <!-- Action -->
           <div class="action-container">
              <a href={`/gauntlet/${gauntlet.gauntletId}`} class="view-button-link">
                <button class="view-button pusab-font">VIEW</button>
              </a>
              <button class="info-button" data-desc={parseDescription(gauntlet.gauntletDescription)} data-name={gauntlet.gauntletName}>
                 <img src="/buttons/RL_info01.png" alt="Info" />
              </button>
           </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Popup Modal -->
  <div id="info-modal" class="modal-overlay hidden">
    <div class="modal-content">
      <h2 id="modal-title" class="pusab-font" style="margin-top: 0;"></h2>
      <div id="modal-desc" class="modal-body"></div>
      <button id="modal-close" class="view-button pusab-font" style="margin-top: 1rem;">CLOSE</button>
    </div>
  </div>
</Layout>

<script>
  const infoButtons = document.querySelectorAll('.info-button');
  const modal = document.getElementById('info-modal');
  const modalTitle = document.getElementById('modal-title');
  const modalDesc = document.getElementById('modal-desc');
  const modalClose = document.getElementById('modal-close');

  if (modal && modalTitle && modalDesc && modalClose) {
    infoButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        modalTitle.innerText = btn.getAttribute('data-name') || '';
        modalDesc.innerHTML = btn.getAttribute('data-desc') || '';
        modal.classList.remove('hidden');
      });
    });

    modalClose.addEventListener('click', () => {
      modal.classList.add('hidden');
    });

    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
      }
    });
  }
</script>

<style>
  .list-container {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1rem;
    animation: fadeIn 0.5s ease-out;
  }

  .header-row {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: 2.5rem;
    text-shadow: 2.5px 2.5px #00000050;
    margin: 0;
  }

  .gauntlets-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
  }

  .gauntlet-cell {
    background: linear-gradient(to bottom, #00d2ff 50%, #31ddfc 50%);
    border: 4px solid #000;
    border-radius: 16px;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 320px;
    box-shadow: 0 6px 15px rgba(0,0,0,0.4);
    transition: transform 0.2s ease;
  }

  .gauntlet-cell:hover {
    transform: translateY(-5px);
  }

  .gauntlet-icon-container {
    margin-bottom: 1.5rem;
    min-height: 120px;
    display: flex;
    align-items: flex-end;
  }

  .gauntlet-icon {
    width: 140px;
    height: auto;
    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.5));
  }

  .gauntlet-info {
    text-align: center;
    margin-bottom: 2rem;
    width: 100%;
  }

  .gauntlet-name {
    font-size: 1.6rem;
    color: white;
    text-shadow: 2.5px 2.5px #00000050;
    text-transform: uppercase;
    display: block;
    line-height: 1.2;
  }

  .action-container {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: 100%;
    justify-content: center;
    margin-top: auto;
  }

  .view-button {
    background: linear-gradient(to bottom, #00d2ff, #0072ff);
    border: 3px solid #000;
    border-radius: 6px;
    color: white;
    padding: 0.5rem 1.2rem;
    font-size: 1.5rem;
    cursor: pointer;
    text-shadow: 2.5px 2.5px #00000050;
    box-shadow: 0 4px 0 #000;
    transition: all 0.1s;
    letter-spacing: 1px;
  }

  .view-button:active {
    transform: translateY(3px);
    box-shadow: 0 1px 0 #000;
  }

  .view-button:hover {
    transform: scale(1.05);
  }

  .info-button {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .info-button img {
    width: 50px;
    height: 50px;
    filter: drop-shadow(0 4px 4px rgba(0,0,0,0.4));
  }

  .info-button:hover {
    transform: scale(1.15);
  }

  .info-button:active {
    transform: scale(0.95);
  }

  /* Modal Overlay */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    backdrop-filter: blur(3px);
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .modal-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .modal-content {
    background: linear-gradient(to bottom, #103b70, #081d38);
    border: 4px solid #4cbdff;
    border-radius: 16px;
    padding: 2.5rem 2rem;
    max-width: 650px;
    width: 90%;
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.8), inset 0 0 20px rgba(76, 189, 255, 0.2);
    text-align: center;
    transform: scale(1);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .modal-overlay.hidden .modal-content {
    transform: scale(0.9);
  }

  .modal-content h2 {
    font-size: 3rem;
    margin-bottom: 2rem;
    text-shadow: 2.5px 2.5px #00000050;
    -webkit-text-stroke: 1.5px black;
  }

  .modal-body {
    font-size: 1.2rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    text-align: left;
    background: rgba(0, 0, 0, 0.35);
    padding: 1.5rem;
    border-radius: 8px;
    border: 2px solid rgba(255, 255, 255, 0.15);
    width: 100%;
    max-height: 50vh;
    overflow-y: auto;
    font-family: var(--font-main);
  }

  .modal-body::-webkit-scrollbar {
    width: 8px;
  }

  .modal-body::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 4px;
  }

  .modal-body::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.3);
    border-radius: 4px;
  }

  .modal-body::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.5);
  }

  .modal-body a {
    color: #00d2ff;
    text-decoration: underline;
    transition: color 0.2s;
  }

  .modal-body a:hover {
    color: #ffc800;
  }
</style>
