---
export const prerender = false;
import Layout from '../layouts/Layout.astro';

const res = await fetch(`https://gdrate.arcticwoof.xyz/v1/getSpire`, {
  cache: 'no-store'
});
const rooms = await res.json() || [];

const getDifficultyPath = (diffValue, featValue) => {
  let diffName = "NA";
  let fileName = "na";
  
  if (diffValue === 1) { diffName = "AUTO"; fileName = "auto"; }
  else if (diffValue === 2) { diffName = "EASY"; fileName = "easy"; }
  else if (diffValue === 3) { diffName = "NORMAL"; fileName = "normal"; }
  else if (diffValue >= 4 && diffValue <= 5) { diffName = "HARD"; fileName = "hard"; }
  else if (diffValue >= 6 && diffValue <= 7) { diffName = "HARDER"; fileName = "harder"; }
  else if (diffValue >= 8 && diffValue <= 9) { diffName = "INSANE"; fileName = "insane"; }
  else if (diffValue === 10) { diffName = "EASY DEMON"; fileName = "easydemon"; }
  else if (diffValue === 15) { diffName = "MEDIUM DEMON"; fileName = "mediumdemon"; }
  else if (diffValue === 20) { diffName = "HARD DEMON"; fileName = "harddemon"; }
  else if (diffValue === 25) { diffName = "INSANE DEMON"; fileName = "insanedemon"; }
  else if (diffValue === 30) { diffName = "EXTREME DEMON"; fileName = "extremedemon"; }
  
  let featName = "no";
  if (featValue === 1) featName = "featured";
  else if (featValue === 2) featName = "epic";
  else if (featValue === 3) featName = "legendary";

  return `/difficulty/${diffName}/${fileName}_${featName}.png`;
};

const getStars = (diffValue) => {
  if (diffValue >= 10) return 10;
  return diffValue;
};
---

<Layout title="The Spire">
  <div class="list-container">
    <div class="header-row">
      <h1 class="page-title pusab-font">The Spire</h1>
    </div>

    <div class="rooms-container">
      {rooms.map((room) => (
        <div class="room-section">
          <div class="room-header-container">
            <h2 class="room-title pusab-font">Room {room.index}</h2>
          </div>
          
          <div class="layouts-list">
            {room.layouts.map((level) => (
              <div class="level-cell">
                <!-- Difficulty Face and Label -->
                <div class="difficulty-container">
                  <img 
                    src={getDifficultyPath(level.difficulty, level.featured)} 
                    alt="Difficulty" 
                    class="difficulty-face"
                  />
                </div>

                <!-- Level Info -->
                <div class="level-info">
                  <div class="name-row">
                    <span class="level-name pusab-font">{level.levelName}</span>
                    <span class="level-stars pusab-font">
                      {getStars(level.difficulty)}
                      <img src={level.type === 'platformer' ? "/stats/RL_planetMed.png" : "/stats/RL_sparkMed.png"} alt="Stars" class="stars-icon" />
                    </span>
                  </div>
                  <div class="creator-row">
                    <span class="by-label pusab-font">By</span>
                    <span class="creator-name pusab-font">{level.creatorUsername}</span>
                  </div>
                </div>

                <!-- Score and View Button -->
                <div class="action-container">
                  <a href={`/level/${level.levelId}`} class="view-button-link">
                    <button class="view-button pusab-font">VIEW</button>
                  </a>
                </div>
              </div>
            ))}
            {room.layouts.length === 0 && (
              <div class="empty-room pusab-font">
                No layouts in this Room yet.
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>

<style>
  .list-container {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1rem;
    animation: fadeIn 0.5s ease-out;
  }

  .header-row {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: 2.8rem;
    text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    margin: 0;
  }

  .room-section {
    margin-bottom: 4rem;
  }

  .room-header-container {
    background: rgba(0, 0, 0, 0.4);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 0.8rem 2rem;
    margin-bottom: 1.5rem;
    width: fit-content;
  }

  .room-title {
    font-size: 1.8rem;
    color: white;
    margin: 0;
    text-shadow: 2px 2px #000;
  }

  .layouts-list {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    padding-left: 1rem;
  }

  .level-cell {
    background: linear-gradient(to bottom, #d2b48c 50%, #bc9b6a 50%);
    border: 4px solid #000;
    border-radius: 12px;
    padding: 1rem 1.8rem;
    display: flex;
    align-items: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
  }

  .difficulty-container {
    margin-right: 1.8rem;
    min-width: 80px;
    display: flex;
    justify-content: center;
  }

  .difficulty-face {
    width: 100px;
    height: auto;
    filter: drop-shadow(0 0 5px rgba(255,255,255,0.3));
  }

  .level-info {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .name-row {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .level-name {
    font-size: 2rem;
    text-transform: uppercase;
    color: white;
    text-shadow: 2px 2px #000;
  }

  .level-stars {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 2rem;
    color: white;
    text-shadow: 2px 2px #000;
  }

  .stars-icon {
    width: 28px;
    height: auto;
  }

  .creator-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .by-label {
    color: #ffc800;
    font-size: 1.6rem;
    text-shadow: 1.5px 1.5px #000;
  }

  .creator-name {
    color: #ffc800;
    font-size: 1.6rem;
    text-shadow: 1.5px 1.5px #000;
  }

  .action-container {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }

  .featured-score {
    font-size: 1.1rem;
    color: #ffd966;
    text-shadow: 1px 1px #000;
    font-weight: bold;
  }

  .view-button {
    background: linear-gradient(to bottom, #00d2ff, #0072ff);
    border: 3px solid #000;
    border-radius: 8px;
    color: white;
    padding: 0.5rem 1.4rem;
    font-size: 1.6rem;
    cursor: pointer;
    text-shadow: 1px 1px #000;
    box-shadow: 0 4px 0 #000;
    transition: all 0.1s;
  }

  .view-button:active {
    transform: translateY(3px);
    box-shadow: 0 1px 0 #000;
  }

  .empty-room {
    padding: 2rem;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 8px;
    border: 2px dashed rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.5);
    font-size: 1.4rem;
    text-align: center;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .level-cell {
      flex-direction: column;
      text-align: center;
    }
    .difficulty-container { margin: 0 0 1rem 0; }
    .name-row, .creator-row { justify-content: center; }
    .action-container { align-items: center; margin-top: 1rem; }
  }
</style>
