---
export const prerender = false;
import Layout from '../layouts/Layout.astro';

const { searchParams } = Astro.url;
const page = parseInt(searchParams.get('page') || '1');
const type = parseInt(searchParams.get('type') || '1');

// Fetch logic
const res = await fetch(`https://gdrate.arcticwoof.xyz/v1/getLeaderboard?type=${type}&page=${page}`, {
  cache: 'no-store'
});
const data = await res.json();
const leaderboard = data.leaderboard || [];
const totalAmount = data.total || 0;
const amountPerPage = data.amount || 100;
const totalPages = Math.ceil(totalAmount / amountPerPage);

let statName = "";
let statIcon = "";
let statKey = "";

if (type === 1) {
    statName = "Sparks";
    statIcon = "/stats/RL_sparkMed.png";
    statKey = "sparks";
} else if (type === 2) {
    statName = "Planets";
    statIcon = "/stats/RL_planetMed.png";
    statKey = "planets";
} else if (type === 3) {
    statName = "Blueprint Points";
    statIcon = "/stats/RL_blueprintPoint.png";
    statKey = "creatorPoints";
} else if (type === 4) {
    statName = "Blue Coins";
    statIcon = "/stats/RL_BlueCoinSmall.png";
    statKey = "blueCoins";
}
---

<Layout title="Leaderboard">
  <div class="list-container">
    <div class="header-row">
      <h1 class="page-title pusab-font">Leaderboard</h1>
      <div class="stats-counter pusab-font">
        <div class="current-page">Page {page}</div>
        <div class="total-levels">Total: {totalAmount}</div>
      </div>
    </div>

    <!-- Type Tabs -->
    <div class="tabs-container">
      <a href="?type=1&page=1" class={`tab-btn ${type === 1 ? 'active' : ''}`}>
        <img src="/stats/RL_sparkMed.png" height="25px" width="auto" alt="Sparks" class="tab-icon" />
        <span class="tab-text pusab-font">Sparks</span>
      </a>
      <a href="?type=2&page=1" class={`tab-btn ${type === 2 ? 'active' : ''}`}>
        <img src="/stats/RL_planetMed.png" height="25px" width="auto" alt="Planets" class="tab-icon" />
        <span class="tab-text pusab-font">Planets</span>
      </a>
      <a href="?type=3&page=1" class={`tab-btn ${type === 3 ? 'active' : ''}`}>
        <img src="/stats/RL_blueprintPoint.png" height="25px" width="auto" alt="Blueprint Pts" class="tab-icon" />
        <span class="tab-text pusab-font">Blueprints</span>
      </a>
      <a href="?type=4&page=1" class={`tab-btn ${type === 4 ? 'active' : ''}`}>
        <img src="/stats/RL_BlueCoinSmall.png" height="25px" width="auto" alt="Blue Coins" class="tab-icon" />
        <span class="tab-text pusab-font">Blue Coins</span>
      </a>
    </div>
    
    <div class="layouts-list">
      {leaderboard.map((user) => (
        <div 
          class="user-cell" 
          style={user.nameplate ? `background: url('https://gdrate.arcticwoof.xyz/nameplates/banner/nameplate_${user.nameplate}.png') center/cover no-repeat, linear-gradient(to bottom, #44e0e2 50%, #186fd2 50%);` : ''}
        >
          <!-- Rank Number -->
          <div class="difficulty-container">
            <span class="rank-number pusab-font">#{user.rank}</span>
          </div>

          <!-- User Info -->
          <div class="user-info">
            <div class="name-row">
              <span class="player-name pusab-font">{user.username}</span>
              <span class="player-stat pusab-font">
                <img src={statIcon} alt={statName} class="stars-icon" />
                {user[statKey]}
              </span>
            </div>
          </div>

          <!-- Action Button -->
          <div class="action-container">
            <a href={`/profile/${user.accountId}`} class="view-button-link" style="margin-top:auto;">
              <button class="view-button pusab-font">VIEW</button>
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Pagination Controls -->
    <div class="pagination-controls">
      <a href={page > 1 ? `?type=${type}&page=${page - 1}` : '#'} 
         class={`nav-button prev-button ${page <= 1 ? 'disabled' : ''}`}>
        <img src="/buttons/RL_prev01.png" alt="Previous" class="nav-button-bg" />
      </a>
      <a href={page < totalPages ? `?type=${type}&page=${page + 1}` : '#'} 
         class={`nav-button next-button ${page >= totalPages ? 'disabled' : ''}`}>
        <img src="/buttons/RL_next01.png" alt="Next" class="nav-button-bg" />
      </a>
    </div>
  </div>
</Layout>

<style>
  .list-container {
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1rem;
    animation: fadeIn 0.5s ease-out;
  }

  .header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    position: relative;
  }

  .page-title {
    font-size: 2.5rem;
    text-shadow: 2.5px 2.5px #00000050;
    margin: 0;
  }

  .stats-counter {
    background: rgba(0, 0, 0, 0.4);
    border: 2px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 0.5rem 1rem;
    text-align: right;
    color: #ffd966;
    text-shadow: 2.5px 2.5px #00000050;
  }

  .current-page {
    font-size: 1.5rem;
    color: white;
  }

  .total-levels {
    font-size: 1rem;
    color: white;
  }

  .tabs-container {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .tab-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(to bottom, #4a4a4a, #2a2a2a);
    border: 3px solid #000;
    border-radius: 6px;
    color: white;
    padding: 0.6rem 1.2rem;
    font-size: 1.2rem;
    text-decoration: none;
    text-shadow: 2.5px 2.5px #00000050;
    transition: all 0.1s;
    box-shadow: 0 4px 0 #000;
  }

  .tab-btn:hover {
    transform: scale(1.05);
  }

  .tab-btn:active {
    transform: translateY(2px);
    box-shadow: 0 2px 0 #000;
  }

  .tab-btn.active {
    background: linear-gradient(to bottom, #00d2ff, #0072ff);
  }

  .layouts-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pagination-controls {
    display: flex;
    justify-content: center;
    gap: 2rem;
    margin-top: 3rem;
  }

  .nav-button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    text-decoration: none;
    width: 60px;
    height: 60px;
    background: none;
    border: none;
    padding: 0;
  }

  .nav-button-bg {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: contain;
    z-index: 1;
    transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .nav-button.disabled {
    opacity: 0.3;
    pointer-events: none;
    cursor: default;
    filter: grayscale(1);
  }

  .nav-button:hover .nav-button-bg {
    transform: scale(1.1);
    filter: drop-shadow(0 5px 10px rgba(0, 0, 0, 0.3));
  }

  .nav-button:active .nav-button-bg {
    transform: scale(0.95);
  }

  .user-cell {
    background: linear-gradient(to bottom, #44e0e2, #186fd2);
    border: 4px solid #000;
    border-radius: 12px;
    padding: 0.8rem 1.5rem;
    display: flex;
    align-items: center;
    position: relative;
    box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    transition: transform 0.2s ease;
  }

  .difficulty-container {
    margin-right: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 80px;
  }

  .rank-number {
    font-size: 2.5rem;
    color: white;
    text-shadow: 2.5px 2.5px #00000050;
  }

  .user-info {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.2rem;
  }

  .name-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .player-name {
    font-size: 1.8rem;
    text-transform: uppercase;
    color: #ffc800;
    text-shadow: 2.5px 2.5px #00000050;
  }

  .player-stat {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 1.8rem;
    color: white;
    text-shadow: 2.5px 2.5px #00000050;
  }

  .stars-icon {
    width: 30px;
    height: auto;
  }

  .action-container {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
    height: 100%;
  }

  .view-button {
    background: linear-gradient(to bottom, #00d2ff, #0072ff);
    border: 3px solid #000;
    border-radius: 6px;
    color: white;
    padding: 0.4rem 1.2rem;
    font-size: 1.5rem;
    cursor: pointer;
    text-shadow: 2.5px 2.5px #00000050;
    box-shadow: 0 4px 0 #000;
    transition: all 0.1s;
  }

  .view-button:active {
    transform: translateY(2px);
    box-shadow: 0 2px 0 #000;
  }

  .view-button:hover {
    transform: scale(1.05);
  }

  @media (max-width: 600px) {
    .user-cell {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 1rem;
    }

    .difficulty-container {
      margin-right: 0;
      margin-bottom: 0.5rem;
    }

    .name-row, .creator-row {
      justify-content: center;
    }

    .action-container {
      align-items: center;
      margin-top: 1rem;
    }
  }
</style>
