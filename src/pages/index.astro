---
import Layout from "../layouts/Layout.astro";
---

<Layout title="GD Rated Layouts Browser">
  <div class="menu-container">
    <a href="/featured" class="menu-button">
      <img src="/menu/RL_featured01.png" alt="Featured" />
    </a>
    <a href="/leaderboard" class="menu-button">
      <img src="/menu/RL_leaderboard01.png" alt="Leaderboard" />
    </a>
    <a href="/gauntlets" class="menu-button">
      <img src="/menu/RL_gauntlets01.png" alt="Gauntlets" />
    </a>
    <a href="/sent" class="menu-button">
      <img src="/menu/RL_sent01.png" alt="Sent" />
    </a>
    <a href="/spire" class="menu-button">
      <img src="/menu/RL_spire01.png" alt="Spire" />
    </a>
    <a href="/search" class="menu-button">
      <img src="/menu/RL_search01.png" alt="Search" />
    </a>
    <a href="/events?type=daily" class="menu-button">
      <img src="/menu/RL_daily01.png" alt="Daily" />
    </a>
    <a href="/events?type=weekly" class="menu-button">
      <img src="/menu/RL_weekly01.png" alt="Weekly" />
    </a>
    <a href="/events?type=monthly" class="menu-button">
      <img src="/menu/RL_monthly01.png" alt="Monthly" />
    </a>
  </div>
  <div class="secondary-menu">
    <a href="#" class="small-button" id="credits-btn">
      <img src="/buttons/RL_credits01.png" alt="Credits" />
    </a>
    <a class="small-button" id="news-btn">
      <img src="/buttons/RL_news01.png" alt="News" />
    </a>
    <a href="#" class="small-button">
      <img src="/buttons/RL_info01.png" alt="Info" />
    </a>
    <a class="small-button" id="random-btn">
      <img src="/buttons/RL_random01.png" alt="Random" />
    </a>
    <a
      href="https://geode-sdk.org/mods/arcticwoof.rated_layouts"
      class="small-button"
    >
      <img src="/buttons/RL_geode01.png" alt="Geode" />
    </a>
    <a href="https://discord.gg/jBf2wfBgVT" class="small-button">
      <img src="/buttons/RL_discord01.png" alt="Discord" />
    </a>
    <a href="https://www.youtube.com/@RatedLayouts" class="small-button">
      <img src="/buttons/RL_youtube01.png" alt="YouTube" />
    </a>
  </div>

  <!-- News Modal -->
  <div id="news-modal" class="modal-overlay hidden">
    <div class="modal-content">
      <h2 id="news-title" class="modal-title pusab-font">
        Rated Layouts Annoucement
      </h2>
      <div id="news-body" class="modal-body">
        <div class="loading-spinner">LOADING...</div>
      </div>
      <button id="ok-btn" class="ok-button pusab-font">OK</button>
    </div>
  </div>
  <div id="credits-modal" class="modal-overlay hidden">
    <div class="modal-content">
      <h2 class="modal-title pusab-font">Rated Layouts Team/Credits</h2>
      <div id="credits-body" class="credits-list"></div>
      <button id="close-credits" class="ok-button pusab-font">OK</button>
    </div>
  </div>
</Layout>

<style>
  .secondary-menu {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    width: 100%;
    max-width: 800px;
    margin: 2rem auto;
    padding: 0 1rem;
  }

  .small-button {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .small-button:hover {
    transform: scale(1.2);
    filter: drop-shadow(0 5px 15px rgba(0, 0, 0, 0.3));
  }

  .small-button:active {
    transform: scale(0.9);
  }

  .small-button img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .secondary-menu {
      gap: 1rem;
    }
    .small-button {
      width: 50px;
      height: 50px;
    }
  }

  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.75);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    backdrop-filter: blur(3px);
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .modal-overlay.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .modal-content {
    background: linear-gradient(to bottom, #103b70, #081d38);
    border: 4px solid #4cbdff;
    border-radius: 16px;
    padding: 2.5rem 2rem;
    max-width: 650px;
    width: 90%;
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow:
      0 0 30px rgba(0, 0, 0, 0.8),
      inset 0 0 20px rgba(76, 189, 255, 0.2);
    text-align: center;
    transform: scale(1);
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .modal-overlay.hidden .modal-content {
    transform: scale(0.9);
  }

  .modal-title {
    font-size: 3rem;
    margin-bottom: 2rem;
    text-shadow: 2px 2px #000;
    font-weight: bold;
    text-transform: uppercase;
    -webkit-text-stroke: 1.5px black !important;
  }

  .modal-body {
    font-size: 1.2rem;
    line-height: 1.6;
    margin-bottom: 2rem;
    text-align: left;
    background: rgba(0, 0, 0, 0.35);
    padding: 1.5rem;
    border-radius: 8px;
    border: 2px solid rgba(255, 255, 255, 0.15);
    width: 100%;
    max-height: 50vh;
    overflow-y: auto;
  }

  .modal-body :global(*),
  .modal-body :global(h1),
  .modal-body :global(h2),
  .modal-body :global(h3) {
    font-family: var(--font-main) !important;
    -webkit-text-stroke: 0 !important;
  }

  .modal-body::-webkit-scrollbar {
    width: 8px;
  }

  .modal-body::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 4px;
  }
  .modal-body::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.3);
    border-radius: 4px;
  }

  .ok-button {
    background: linear-gradient(to bottom, #00d2ff, #0072ff);
    border: 3px solid #000;
    border-radius: 6px;
    color: white;
    padding: 0.5rem 1.2rem;
    font-size: 1.5rem;
    cursor: pointer;
    text-shadow: 1px 1px #000;
    box-shadow: 0 4px 0 #000;
    transition: all 0.1s;
    letter-spacing: 1px;
  }

  .ok-button:active {
    transform: translateY(3px);
    box-shadow: 0 1px 0 #000;
  }

  /* Markdown Content Styles */
  .modal-body :global(h1),
  .modal-body :global(h2),
  .modal-body :global(h3) {
    color: #ffd966;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .modal-body :global(p) {
    margin-bottom: 1rem;
  }
  .modal-body :global(a) {
    color: #4cbdff;
    text-decoration: underline;
    transition: color 0.1s;
  }
  .modal-body :global(a:hover) {
    color: #00d2ff;
  }
  .modal-body :global(code) {
    background: rgba(0, 0, 0, 0.3);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
  }

  .credits-list {
    width: 100%;
    max-height: 55vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1rem;
    margin-bottom: 2rem;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 12px;
    border: 3px solid #000;
  }

  .credits-list :global(.credit-section) {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .credits-list :global(.role-title) {
    color: #ffc800;
    font-size: 1.4rem;
    padding-bottom: 0.3rem;
    font-weight: bold;
    text-transform: uppercase;
    text-shadow: 2px 2px #000;
    font-family: var(--font-heading), sans-serif !important;
    -webkit-text-stroke: 1px black;
    text-align: left;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .credits-list :global(.role-title::after) {
    content: "";
    flex-grow: 1;
    height: 3px;
    background: rgba(255, 200, 0, 0.3);
    border-radius: 2px;
  }

  .credits-list :global(.user-column) {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    width: 100%;
  }

  .credits-list :global(.credit-user-cell) {
    background: linear-gradient(
      to bottom,
      #44e0e2,
      #186fd2
    ); /* Leaderboard colors */
    border: 3px solid #000;
    border-radius: 8px;
    padding: 0.7rem 1.2rem;
    display: flex;
    align-items: center;
    gap: 1.2rem;
    /* 3D Inset Shadow from Leaderboard cells */
    box-shadow:
      inset 0 -4px 0 rgba(0, 0, 0, 0.4),
      0 4px 10px rgba(0, 0, 0, 0.3);
    transition: transform 0.1s ease;
    text-decoration: none;
    position: relative;
    height: 65px;
  }

  .credits-list :global(.credit-user-cell:hover) {
    transform: scale(1.02);
    filter: brightness(1.1);
  }

  .credits-list :global(.badge-container) {
    display: flex;
    justify-content: center;
    align-items: center;
    min-width: 50px;
  }

  .credits-list :global(.badge-container img) {
    width: 42px;
    height: 42px;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.5));
  }

  .credits-list :global(.credit-user-name) {
    color: white;
    font-size: 1.6rem;
    text-transform: uppercase;
    text-shadow: 2px 2px #000;
    font-family: var(--font-heading), sans-serif !important;
    -webkit-text-stroke: 1.5px black;
    flex-grow: 1;
    text-align: left;
    letter-spacing: 1px;
  }
</style>

<script>
  import { marked } from "marked";

  // Random Button Logic
  const randomBtn = document.getElementById("random-btn");
  if (randomBtn) {
    randomBtn.addEventListener("click", async (e) => {
      e.preventDefault();
      randomBtn.style.opacity = "0.5";
      randomBtn.style.pointerEvents = "none";
      try {
        const res = await fetch("/api/getRandomLevel");
        const data = await res.json();
        if (data && data.levelId) {
          window.location.href = `/level/${data.levelId}`;
        }
      } catch (err) {
        console.error("Failed to fetch random level:", err);
        randomBtn.style.opacity = "1";
        randomBtn.style.pointerEvents = "auto";
      }
    });
  }

  // News Modal Logic
  const newsBtn = document.getElementById("news-btn");
  const newsModal = document.getElementById("news-modal");
  const newsBody = document.getElementById("news-body");
  const okBtn = document.getElementById("ok-btn");

  const openModal = async () => {
    newsModal?.classList.remove("hidden");
    newsBody!.innerHTML = '<div class="loading-spinner">LOADING...</div>';

    try {
      const res = await fetch("/api/getAnnoucement");
      const data = await res.json();
      if (data && data.body) {
        // Simple regex to fix common GD tags like <cl>, <cg>, etc.
        let cleanedBody = data.body
          .replace(/<cf>/g, '<span style="color: #ffc800">')
          .replace(/<cl>/g, '<span style="color: #4cbdff">')
          .replace(/<cg>/g, '<span style="color: #40ff40">')
          .replace(/<cr>/g, '<span style="color: #ff4040">')
          .replace(/<cp>/g, '<span style="color: #ff40ff>')
          .replace(/<\/c>/g, "</span>");

        newsBody!.innerHTML = await marked.parse(cleanedBody);
      }
    } catch (err) {
      newsBody!.innerHTML =
        '<div style="color: #ff4040">Failed to load news. Please try again later.</div>';
    }
  };

  const closeModal = () => {
    newsModal?.classList.add("hidden");
  };

  newsBtn?.addEventListener("click", (e) => {
    e.preventDefault();
    openModal();
  });

  okBtn?.addEventListener("click", closeModal);

  // Close on backdrop click
  newsModal?.addEventListener("click", (e) => {
    if (e.target === newsModal) closeModal();
  });
  // Credits Modal Logic
  const creditsBtn = document.getElementById("credits-btn");
  const creditsModal = document.getElementById("credits-modal");
  const creditsBody = document.getElementById("credits-body");
  const closeCredits = document.getElementById("close-credits");

  const badgeMap = {
    owner: "RL_badgeOwner.png",
    classicAdmins: "RL_badgeAdmin01.png",
    classicModerators: "RL_badgeMod01.png",
    platAdmins: "RL_badgePlatAdmin01.png",
    platModerators: "RL_badgePlatMod01.png",
    leaderboardAdmins: "RL_badgelbAdmin01.png",
    leaderboardModerators: "RL_badgelbMod01.png",
    supporters: "RL_badgeSupporter.png",
    boosters: "RL_badgeBooster.png",
  };

  const roleLabels = {
    owner: "Rated Layouts Owner",
    classicAdmins: "Classic Admins",
    classicModerators: "Classic Moderators",
    platAdmins: "Platformer Admins",
    platModerators: "Platformer Moderators",
    leaderboardAdmins: "Leaderboard Admins",
    leaderboardModerators: "Leaderboard Moderators",
    supporters: "Layout Supporters",
    boosters: "LayoutBoosters",
  };

  const openCredits = async () => {
    creditsModal?.classList.remove("hidden");
    creditsBody!.innerHTML = '<div class="loading-spinner">LOADING...</div>';

    try {
      const res = await fetch("/api/getCredits");
      const data = await res.json();

      if (data && data.success) {
        let html = "";
        const roles = [
          "owner",
          "classicAdmins",
          "classicModerators",
          "platAdmins",
          "platModerators",
          "leaderboardAdmins",
          "leaderboardModerators",
          "supporters",
          "boosters",
        ];

        roles.forEach((role) => {
          const users = data[role];
          if (users && users.length > 0) {
            html += `
              <div class="credit-section">
                <div class="role-title">${roleLabels[role]}</div>
                <div class="user-column">
                  ${users
                    .map(
                      (u) => `
                    <a href="/profile/${u.accountId}" class="credit-user-cell">
                      <div class="badge-container">
                        <img src="/badge/${badgeMap[role]}" alt="${role}" />
                      </div>
                      <span class="credit-user-name">${u.username}</span>
                    </a>
                  `,
                    )
                    .join("")}
                </div>
              </div>
            `;
          }
        });
        creditsBody!.innerHTML = html;
      }
    } catch (err) {
      creditsBody!.innerHTML = "Failed to load credits.";
    }
  };

  creditsBtn?.addEventListener("click", (e) => {
    e.preventDefault();
    openCredits();
  });
  closeCredits?.addEventListener("click", () =>
    creditsModal?.classList.add("hidden"),
  );
  creditsModal?.addEventListener("click", (e) => {
    if (e.target === creditsModal) creditsModal.classList.add("hidden");
  });
</script>
