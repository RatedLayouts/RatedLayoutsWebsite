---
import "../styles/global.css";
import { inject } from "@vercel/analytics";
import SpeedInsights from "@vercel/speed-insights/astro";
const { title = "Rated Layouts" } = Astro.props;
inject();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <link href="https://fonts.cdnfonts.com/css/pusab" rel="stylesheet" />
  </head>
  <body>
    <SpeedInsights />
    <header class="navbar">
      <div class="navbar-wrapper">
        <a href="/" class="logo">
          <img src="/RL_title.png" alt="Logo" height="50" width="auto" />
        </a>
      </div>
    </header>
    <main id="page-root">
      <div class="content-wrapper">
        <slot />
      </div>
      <footer class="footer">
        <div class="footer-content">
          <p class="footer-copyright">
            &copy; {new Date().getFullYear()} ArcticWoof | All Rights Reserved | Not
            affiliated with RobTop Games.
          </p>
          <p class="footer-assets">Rated Layouts Assets by Dasshu & Darkore</p>
        </div>
      </footer>
    </main>
  </body>
</html>
